{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LiteratureList",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "writer"],
    "properties": {
      "id": {
        "type": "integer"
      },
      "name": {
        "type": "string"
      },
      "writer": {
        "type": "string"
      }
    }
  }
}
