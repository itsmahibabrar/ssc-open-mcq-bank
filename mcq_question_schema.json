{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Questionnaire",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["type", "board", "chapter"],
    "properties": {
      "type": {
        "type": "string",
        "enum": ["question", "passage"]
      },
      "board": {
        "type": "integer"
      },
      "chapter": {
        "type": "integer"
      },
      "id": {
        "type": "integer"
      },
      "question": {
        "type": "string"
      },
      "option_a": {
        "type": "string"
      },
      "option_b": {
        "type": "string"
      },
      "option_c": {
        "type": "string"
      },
      "option_d": {
        "type": "string"
      },
      "correct_option": {
        "type": "string",
        "enum": ["option_a", "option_b", "option_c", "option_d"]
      },
      "text": {
        "type": "string"
      },
      "questions": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "question", "option_a", "option_b", "option_c", "option_d", "correct_option", "type"],
          "properties": {
            "id": {
              "type": "integer"
            },
            "question": {
              "type": "string"
            },
            "option_a": {
              "type": "string"
            },
            "option_b": {
              "type": "string"
            },
            "option_c": {
              "type": "string"
            },
            "option_d": {
              "type": "string"
            },
            "correct_option": {
              "type": "string",
              "enum": ["option_a", "option_b", "option_c", "option_d"]
            },
            "type": {
              "type": "string",
              "enum": ["question"]
            }
          }
        }
      }
    },
    "allOf": [
      {
        "if": {
          "properties": { "type": { "const": "question" } }
        },
        "then": {
          "required": ["id", "question", "option_a", "option_b", "option_c", "option_d", "correct_option"]
        }
      },
      {
        "if": {
          "properties": { "type": { "const": "passage" } }
        },
        "then": {
          "required": ["text", "questions"]
        }
      }
    ]
  }
}
